# Supabase PostgreSQL (pooler — use in app)
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase direct connection (required for Prisma migrations)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Supabase Storage (KYC uploads) — optional; without these, KYC saves metadata only
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_KYC_BUCKET="kyc"

# Razorpay (test or live)
NEXT_PUBLIC_RAZORPAY_MODE=test
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Cron job auth (ROI auto-credit, scheduled notifications)
CRON_SECRET=generate-a-random-secret

# Resend email (optional — logs to console in dev without key)
RESEND_API_KEY=re_xxx
EMAIL_FROM="Finmora <onboarding@resend.dev>"

# Expo Android app — API base URL (also set in mobile/.env)
# Emulator: http://10.0.2.2:3000 | Physical device: http://<PC-LAN-IP>:3000
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Optional: admin seed password (defaults in seed script)
ADMIN_PASSWORD="Admin@123"
