# Production (physical device / Expo Go on any network)
EXPO_PUBLIC_API_URL=https://finmora.vercel.app

# Android Emulator (maps host localhost to 10.0.2.2)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Physical device on same WiFi — replace with your PC LAN IP + dev server port
# EXPO_PUBLIC_API_URL=http://192.168.43.39:3001

# USB debugging with adb reverse (run: adb reverse tcp:3000 tcp:3000)
# EXPO_PUBLIC_API_URL=http://localhost:3000
